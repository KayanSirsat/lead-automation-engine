GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
NVIDIA_API_KEY=
LLM_MODEL_NAME=meta/llama-3.1-70b-instruct

# ============================================================
# Email Configuration (Phase 4 — Outreach Delivery)
# ============================================================

# Email Provider: "smtp" or "sendgrid"
EMAIL_PROVIDER=smtp

# ── SMTP Configuration (for Gmail, Outlook, etc.) ───────────
# Required if EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com

# Gmail App Password Instructions:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate an app password for "Mail"
# 5. Use that 16-character password as SMTP_PASSWORD

# ── SendGrid Configuration (alternative to SMTP) ────────────
# Required if EMAIL_PROVIDER=sendgrid
# Uncomment these if using SendGrid:
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=verified_sender@yourdomain.com

# SendGrid Setup Instructions:
# 1. Sign up at https://sendgrid.com/
# 2. Create an API key at https://app.sendgrid.com/settings/api_keys
# 3. Verify your sender email at https://app.sendgrid.com/settings/sender_auth
# 4. Install the SDK: pip install sendgrid
